# OpenAI — used for Whisper transcription
OPENAI_API_KEY=

# Anthropic — used to rank/pick the best moments
ANTHROPIC_API_KEY=

# Upload-Post — handles posting to TikTok / IG / FB
# This should be the profile in your Upload-Post dashboard that has
# Mystery Hits Factory's TikTok + IG + FB connected. Likely a DIFFERENT
# profile than the one you use for Gold Touch List.
UPLOAD_POST_API_KEY=
UPLOAD_POST_USER=

# Brand handles — used in captions and end cards
WHATNOT_HANDLE=mysteryhitsfactory
TIKTOK_HANDLE=mystery.hits.factory
INSTAGRAM_HANDLE=mystery.hits.factory
FACEBOOK_PAGE=Mystery Hits Factory
